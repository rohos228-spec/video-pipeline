# Copy to fleet/secrets.env on hub after export-fleet-manifest.ps1
# For private repo ONLY you may commit fleet/secrets.env (not recommended for public repos).

FLEET_AGENT_TOKEN=change-me-long-secret
WEB_AUTH_USER=admin
WEB_AUTH_PASSWORD=change-me

# Headless Tailscale on new worker (no browser login):
# Admin -> https://login.tailscale.com/admin/settings/keys -> Generate auth key
# Reusable key = one key for all your PCs. One-off = single machine.
TAILSCALE_AUTH_KEY=
