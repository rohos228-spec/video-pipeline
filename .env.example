# === Telegram (опционально — для web-only оставьте пустым) ===
TELEGRAM_BOT_TOKEN=
TELEGRAM_ENABLED=false
TELEGRAM_OWNER_CHAT_ID=279887118
# Опционально — если api.telegram.org заблокирован и нужно ходить через прокси:
# TELEGRAM_PROXY_URL=socks5://user:pass@host:1080
# TELEGRAM_PROXY_URL=http://user:pass@host:3128
TELEGRAM_PROXY_URL=

# === Database (SQLite, локальный файл) ===
# На Windows можно указать абсолютный путь вида C:/Users/<user>/vp_state.db
SQLITE_PATH=./data/state.db

# Browser (Playwright к твоему Chrome через CDP) ===
# Запуск: Start-Chrome.cmd  (профиль = логины ChatGPT/outsee)
# Перенос с другого ПК: Restore-Chrome-Profile.cmd
BROWSER_CDP_URL=http://localhost:29229
# Профиль Chrome (по умолчанию %USERPROFILE%\.vp_browser_data):
# BROWSER_USER_DATA_DIR=C:\Users\Love Space\.vp_browser_data

# === outsee.io ===
OUTSEE_IMAGE_URL=https://outsee.io/image?model=gpt-image-2
OUTSEE_VIDEO_URL=https://outsee.io/video?model=veo-3-fast
# true = одна очередь Outsee (картинки+видео), без галереи по [ID: …]
OUTSEE_QUEUE_MODE=true

# === Grsai API (image/video без Chrome/CDP) ===
# Ключ: https://grsai.com/dashboard — НЕ коммить в git
GRSAI_API_KEY=
GRSAI_BASE_URL=https://grsaiapi.com
# grsai | outsee — кто рисует img/hero/items
IMAGE_PROVIDER=grsai
# grsai | outsee — Create video (Sora2 / Veo)
VIDEO_PROVIDER=grsai
GRSAI_DEFAULT_IMAGE_MODEL=gpt-image-2
GRSAI_DEFAULT_VIDEO_MODEL=sora-2

# === 11Labs ===
ELEVENLABS_WEB_URL=https://elevenlabs.io/app/speech-synthesis

# === MoreLogin / публикация ===
MORELOGIN_PROFILE_ID=
SOCIAL_PUBLISH_ENABLED=false

# === Пути для хранения артефактов (картинки, видео, аудио, финалки) ===
# Paths
DATA_DIR=./data
# Явный шаблон project.xlsx (иначе берётся самый свежий templates/project_template_v8*.xlsx)
# PROJECT_XLSX_TEMPLATE=./templates/project_template_v8.xlsx

# === Whisper (faster-whisper) ===
# tiny | base | small | medium | large-v3
# medium — хороший компромисс скорости/качества на CPU
WHISPER_MODEL=medium
# Windows: без symlink в HF cache (WinError 1314)
HF_HUB_DISABLE_SYMLINKS=1
# Не гонять Whisper второй раз на шаге «Сборка»
SUBTITLE_REWHISPER_ON_ASSEMBLE=false

# === ASR (озвучка / монтаж) ===
# nvidia = NeMo Parakeet (~4–8 ГБ RAM после первого «Аудио»); whisper = fallback
ASR_BACKEND=nvidia
# Не грузить Parakeet при старте Studio — только при шаге «Аудио» / remount
NVIDIA_ASR_PRELOAD_ON_STARTUP=false
# true — держать модель в памяти сразу после запуска (быстрее первое «Аудио», +8 ГБ)
# NVIDIA_ASR_PRELOAD_ON_STARTUP=true

# === Логика ===
LOG_LEVEL=INFO
# true — авто-продвижение HITL даже без project.auto_mode
HITL_AUTO_APPROVE=false

# === Web UI (FastAPI + Next.js) ===
WEB_ENABLED=true
WEB_HOST=127.0.0.1
WEB_PORT=8765
