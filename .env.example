# === Browser (Playwright через существующий Chrome по CDP) ===
# Chrome должен быть запущен локально (вне Docker) с флагом
# --remote-debugging-port=29229 --user-data-dir=/home/ubuntu/.browser_data_dir
BROWSER_CDP_URL=http://host.docker.internal:29229

# === outsee.io ===
