# === Telegram ===
TELEGRAM_BOT_TOKEN=
TELEGRAM_OWNER_CHAT_ID=279887118
# Опционально — если api.telegram.org заблокирован и нужно ходить через прокси:
# TELEGRAM_PROXY_URL=socks5://user:pass@host:1080
# TELEGRAM_PROXY_URL=http://user:pass@host:3128
TELEGRAM_PROXY_URL=

# === AI-control + AI-агент в Telegram (Phase I) ===
# Используется и в orchestrator-control.ps1, и в команде /ai в Telegram-боте.
# Рекомендуем aitunnel.ru — OpenAI-совместимый агрегатор для РФ, оплата рублями,
# без VPN. Альтернативно — прямой OpenAI / OpenRouter.
ORCHESTRATOR_AI_BASE_URL=https://api.aitunnel.ru/v1/
ORCHESTRATOR_AI_API_KEY=
ORCHESTRATOR_AI_MODEL=gpt-4o-mini

# Pro-модель для /ai pro команды (тяжёлые задачи).
ORCHESTRATOR_AI_PRO_MODEL=gpt-4o

# Code-tuned модель для /ai claude команды (сложные рефакторинги).
AI_AGENT_CODE_MODEL=claude-opus-4.1

# === Лимиты AI-агента ===
# Защита от runaway-сессии: лимит токенов в одной сессии (≈$0.30 на gpt-4.1-mini).
AI_AGENT_MAX_TOKENS_PER_SESSION=200000
# Макс. шагов tool-call loop (защита от циклов).
AI_AGENT_MAX_STEPS=30
# Дневной лимит (≈$3/день на gpt-4.1-mini).
AI_AGENT_MAX_TOKENS_PER_DAY=2000000
# Таймаут на ответ owner'а в HITL-апруве правок (секунды).
AI_AGENT_HITL_TIMEOUT_SEC=1800
# Таймаут idle сессии до авто-cancel (секунды).
AI_AGENT_IDLE_TIMEOUT_SEC=3600
# Таймаут на запуск тестов / линтера в tool'е (секунды).
AI_AGENT_TOOL_TIMEOUT_SEC=120

# === Database (SQLite, локальный файл) ===
# На Windows можно указать абсолютный путь вида C:/Users/<user>/vp_state.db
SQLITE_PATH=./data/state.db

# === Browser (Playwright к твоему Chrome через CDP) ===
# Запусти Chrome один раз командой (см. HOW_TO_RUN.md):
#   chrome.exe --remote-debugging-port=29229 --user-data-dir=%USERPROFILE%\.vp_browser_data
BROWSER_CDP_URL=http://localhost:29229

# === outsee.io ===
OUTSEE_IMAGE_URL=https://outsee.io/image?model=nano-banana-2
OUTSEE_VIDEO_URL=https://outsee.io/video?model=veo-3-fast

# === 11Labs ===
ELEVENLABS_WEB_URL=https://elevenlabs.io/app/speech-synthesis

# === Dolphin Anty (для шага 10 «Аудио» — открывает 11Labs в антидетект-профиле) ===
# Запусти Dolphin Anty с включённым Local API (Settings → API).
# Сгенерируй токен и подставь сюда. Профиль должен быть залогинен в elevenlabs.io.
DOLPHIN_API_HOST=http://127.0.0.1:3001
DOLPHIN_API_TOKEN=
DOLPHIN_PROFILE_ID=

# === MoreLogin / публикация ===
MORELOGIN_PROFILE_ID=
SOCIAL_PUBLISH_ENABLED=false

# === Пути для хранения артефактов (картинки, видео, аудио, финалки) ===
DATA_DIR=./data

# === Whisper (faster-whisper) ===
# tiny | base | small | medium | large-v3
# medium — хороший компромисс скорости/качества на CPU
WHISPER_MODEL=medium

# === Логика ===
LOG_LEVEL=INFO
HITL_AUTO_APPROVE=false
