# === ASR (на ПК монтажа) ===
# nvidia = NeMo Parakeet | whisper = faster-whisper fallback
ASR_BACKEND=nvidia
NVIDIA_ASR_MODEL=nvidia/stt_ru_fastconformer_hybrid_large_pc
WHISPER_MODEL=large-v3
WHISPER_DEVICE=cuda
WHISPER_COMPUTE_TYPE=float16

# === Fleet / Tailscale ===
FLEET_ENABLED=true
# hub = управление + монтаж | agent = генерация на воркере
FLEET_ROLE=hub
FLEET_MONTAGE_HUB=true
FLEET_MONTAGE_MAX_PARALLEL=1
FLEET_AUTO_PULL=true
# Tailscale URL этого ПК (Settings → Tailscale → IP, порт Studio)
FLEET_PUBLIC_URL=http://100.x.x.x:8765
FLEET_HUB_URL=http://100.x.x.x:8765
FLEET_AGENT_TOKEN=change-me-long-secret
FLEET_NODE_NAME=montage-pc

# === Web auth (fleet + удалённое управление) ===
WEB_AUTH_USER=admin
WEB_AUTH_PASSWORD=change-me
